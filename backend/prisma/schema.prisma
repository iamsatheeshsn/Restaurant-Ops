datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMS ---

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum RoleName {
  SUPER_ADMIN
  OWNER
  AREA_MANAGER
  BRANCH_MANAGER
  KITCHEN_MANAGER
  CHEF
  SOUS_CHEF
  KITCHEN_STAFF
  WAITER
  CASHIER
  INVENTORY_MANAGER
  PURCHASE_MANAGER
  DELIVERY_MANAGER
  DELIVERY_STAFF
  HR_MANAGER
  ACCOUNTANT
  MARKETING_MANAGER
  SYSTEM_AUDITOR
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
  DELIVERY
  ONLINE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum IngredientUnit {
  KG
  GRAM
  LITER
  ML
  PCS
  BOX
}

enum MovementType {
  STOCK_IN
  STOCK_OUT
  WASTE
  TRANSFER_IN
  TRANSFER_OUT
}

enum POStatus {
  DRAFT
  PENDING
  ACCEPTED
  SHIPPED
  DELIVERED
  CANCELLED
  PAID
  RETURNED
}

enum NotificationType {
  ALERT
  INFO
  SYSTEM
}

enum ReportType {
  SALES
  INVENTORY
  WASTE
  FOOD_COST
}

// --- MODELS ---

model Tenant {
  id           String         @id @default(uuid()) @db.VarChar(36)
  name         String
  companyName  String
  /// Public storefront path segment, e.g. "spice-haven" → /r/spice-haven
  slug         String?        @unique @db.VarChar(100)
  status       TenantStatus   @default(TRIAL)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  // Relations
  subscriptions  Subscription[]
  settings       TenantSettings?
  users          User[]
  branches       Branch[]
  floors         Floor[]
  tables         Table[]
  sections       KitchenSection[]
  categories     MenuCategory[]
  menuItems      MenuItem[]
  modifiers      MenuModifier[]
  ingredients    Ingredient[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  orders         Order[]
  movements      StockMovement[]
  wasteLogs      WasteLog[]
  attendances    StaffAttendance[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  savedReports   SavedReport[]
  roles          Role[]
  giftCards      GiftCard[]
  coupons        Coupon[]
  reservations   Reservation[]
  waitingLists   WaitingList[]
  eventBookings  EventBooking[]
  productionBatches ProductionBatch[]
  invoices       Invoice[]
  supportTickets SupportTicket[]
  expenses       Expense[]
  staffSchedules StaffSchedule[]
  leaveRequests  LeaveRequest[]
  deliveryJobs   DeliveryJob[]
  marketingCampaigns MarketingCampaign[]
  stockTransferRequests StockTransferRequest[]
  approvalRequests ApprovalRequest[]

  @@index([status, deletedAt])
}

model Subscription {
  id                   String           @id @default(uuid()) @db.VarChar(36)
  tenantId             String           @db.VarChar(36)
  tenant               Tenant           @relation(fields: [tenantId], references: [id])
  stripeSubscriptionId String?          @db.VarChar(150)
  planTier             SubscriptionTier @default(STARTER)
  status               String           @db.VarChar(50)
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  maxBranches          Int              @default(1)
  maxEmployees         Int              @default(5)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  @@index([tenantId, deletedAt])
}

model TenantSettings {
  id                    String   @id @default(uuid()) @db.VarChar(36)
  tenantId              String   @unique @db.VarChar(36)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency              String   @default("USD") @db.VarChar(10)
  timezone              String   @default("UTC") @db.VarChar(100)
  lowStockNotification  Boolean  @default(true)
  autoCloseShiftsAt     String?  @db.VarChar(10) // HH:MM format
  appName              String   @default("Tastyc") @db.VarChar(100)
  logo                 String?  @db.Text
  favicon              String?  @db.Text
  homeBannerTitle      String   @default("Savor Every Moment") @db.VarChar(255)
  homeBannerSubtitle   String   @default("Welcome to Tastyc Coffee House, where coffee meets cozy luxury.") @db.Text
  homeBannerImage      String?  @db.Text
  ourStoryTitle        String   @default("Our Legacy & Craft") @db.VarChar(255)
  ourStoryContent      String   @default("Established with a passion for roasting premium quality beans, Tastyc has grown into a neighborhood staple. Every cup is brewed with meticulous precision to deliver an unforgettable taste profile.") @db.Text
  ourStoryImage        String?  @db.Text
  platformHighlights   String   @default("100% Organic Beans, Artisanal Brewing, Cozy Atmosphere, Fresh Pastries") @db.Text
  highlightsTitle      String   @default("Engineered For Excellence") @db.VarChar(255)
  highlightsDescription String   @default("Platform Highlights") @db.Text
  coffeeHouseCaption   String   @default("Artisan Coffee & Cozy Spaces") @db.VarChar(255)
  hoursOfService       String   @default("Monday - Friday: 7:00 AM - 9:00 PM, Saturday - Sunday: 8:00 AM - 10:00 PM") @db.Text
  findUsAddress        String   @default("123 Luxury Lounge Blvd, Coffee District, CA 90210") @db.Text
  findUsPhone          String   @default("+1 (555) 123-4567") @db.VarChar(50)
  findUsEmail          String   @default("hello@tastyc.com") @db.VarChar(100)
  findUsMapUrl         String?  @db.Text
  footerContent        String   @default("© 2026 Tastyc. All rights reserved. Crafted for food and coffee lovers.") @db.Text
  updatedAt             DateTime @updatedAt
}

model Branch {
  id           String    @id @default(uuid()) @db.VarChar(36)
  tenantId     String    @db.VarChar(36)
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String    @db.VarChar(150)
  address      String    @db.Text
  phone        String    @db.VarChar(50)
  email        String?   @db.VarChar(100)
  currency     String    @default("USD") @db.VarChar(10)
  country      String    @default("US") @db.VarChar(50)
  isCentralKitchen Boolean @default(false)
  isWarehouse    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  users          User[]
  floors         Floor[]
  sections       KitchenSection[]
  orders         Order[]
  stockMovements StockMovement[]
  wasteLogs      WasteLog[]
  savedReports   SavedReport[]
  eventBookings  EventBooking[]
  productionBatches ProductionBatch[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, deletedAt])
}

model User {
  id           String    @id @default(uuid()) @db.VarChar(36)
  /// Null for global platform users (SUPER_ADMIN). Restaurant staff always have a tenant.
  tenantId     String?   @db.VarChar(36)
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  email        String    @db.VarChar(150)
  passwordHash String    @db.VarChar(255)
  name         String    @db.VarChar(150)
  phone        String?   @db.VarChar(50)
  roleId       String    @db.VarChar(36)
  role         Role      @relation(fields: [roleId], references: [id])
  branchId     String?   @db.VarChar(36)
  branch       Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  orders         Order[]
  movements      StockMovement[]
  wasteLogs      WasteLog[]
  attendances    StaffAttendance[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  savedReports   SavedReport[]
  customerProfile CustomerProfile?

  @@unique([email, tenantId, deletedAt])
  @@index([tenantId, email, deletedAt])
  @@index([email, deletedAt])
  @@index([roleId, deletedAt])
}

model Role {
  id          String           @id @default(uuid()) @db.VarChar(36)
  /// Null for the global SUPER_ADMIN role. Restaurant roles always have a tenant.
  tenantId    String?          @db.VarChar(36)
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  name        String           @db.VarChar(100) // e.g. OWNER, CHEF, CUSTOMER or Custom Roles
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name, deletedAt])
  @@index([name, deletedAt])
}

model Permission {
  id          String           @id @default(uuid()) @db.VarChar(36)
  scope       String           @unique @db.VarChar(100) // e.g. "inventory:adjust"
  description String           @db.VarChar(255)
  roles       RolePermission[]
}

model RolePermission {
  roleId       String     @db.VarChar(36)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.VarChar(36)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
}

model Floor {
  id       String  @id @default(uuid()) @db.VarChar(36)
  tenantId String  @db.VarChar(36)
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  branchId String  @db.VarChar(36)
  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String  @db.VarChar(100)
  tables   Table[]

  @@index([tenantId, branchId])
}

model Table {
  id              String  @id @default(uuid()) @db.VarChar(36)
  tenantId        String  @db.VarChar(36)
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  floorId         String  @db.VarChar(36)
  floor           Floor   @relation(fields: [floorId], references: [id], onDelete: Cascade)
  number          String  @db.VarChar(50)
  seatingCapacity Int     @default(2)
  qrToken         String  @unique @db.VarChar(255)
  orders          Order[]
  reservations    Reservation[]

  @@unique([floorId, number])
}

model KitchenSection {
  id       String @id @default(uuid()) @db.VarChar(36)
  tenantId String @db.VarChar(36)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  branchId String @db.VarChar(36)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String @db.VarChar(100)

  @@unique([branchId, name])
}

model MenuCategory {
  id        String    @id @default(uuid()) @db.VarChar(36)
  tenantId  String    @db.VarChar(36)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  items     MenuItem[]

  @@index([tenantId, deletedAt])
}

model MenuItem {
  id           String       @id @default(uuid()) @db.VarChar(36)
  tenantId     String       @db.VarChar(36)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  categoryId   String       @db.VarChar(36)
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  name         String       @db.VarChar(150)
  description  String?      @db.Text
  price        Decimal      @db.Decimal(10, 2)
  imageUrl     String?      @db.VarChar(255)
  isAvailable  Boolean      @default(true)
  happyHourPrice Decimal?   @db.Decimal(10, 2)
  happyHourStart String?    @db.VarChar(5)
  happyHourEnd   String?    @db.VarChar(5)
  isCombo        Boolean      @default(false)
  comboItems     String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  // Relations
  modifiers    MenuModifier[]
  recipes      Recipe[]
  orderItems   OrderItem[]
  nutritionInfo NutritionInfo?

  @@index([categoryId, deletedAt])
  @@index([tenantId, deletedAt])
}

model MenuModifier {
  id          String              @id @default(uuid()) @db.VarChar(36)
  tenantId    String              @db.VarChar(36)
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  menuItemId  String              @db.VarChar(36)
  menuItem    MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String              @db.VarChar(150)
  price       Decimal             @default(0.00) @db.Decimal(10, 2)
  isAvailable Boolean             @default(true)
  orderMods   OrderItemModifier[]

  @@index([menuItemId])
}

model Ingredient {
  id                String              @id @default(uuid()) @db.VarChar(36)
  tenantId          String              @db.VarChar(36)
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  name              String              @db.VarChar(150)
  unit              IngredientUnit
  stockLevel        Decimal             @default(0.000) @db.Decimal(12, 3)
  lowStockThreshold Decimal             @default(1.000) @db.Decimal(12, 3)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  // Relations
  recipes           Recipe[]
  poItems           PurchaseOrderItem[]
  movements         StockMovement[]
  wasteLogs         WasteLog[]

  @@index([tenantId, deletedAt])
}

model Recipe {
  id           String     @id @default(uuid()) @db.VarChar(36)
  menuItemId   String     @db.VarChar(36)
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String     @db.VarChar(36)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(12, 3)

  @@unique([menuItemId, ingredientId])
}

model Supplier {
  id             String          @id @default(uuid()) @db.VarChar(36)
  tenantId       String          @db.VarChar(36)
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  name           String          @db.VarChar(150)
  contactName    String?         @db.VarChar(150)
  phone          String          @db.VarChar(50)
  email          String?         @db.VarChar(150)
  createdAt      DateTime        @default(now())
  deletedAt      DateTime?
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, deletedAt])
}

model PurchaseOrder {
  id           String              @id @default(uuid()) @db.VarChar(36)
  tenantId     String              @db.VarChar(36)
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  poNumber     String              @db.VarChar(100)
  supplierId   String              @db.VarChar(36)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  status       POStatus            @default(DRAFT)
  totalAmount  Decimal             @default(0.00) @db.Decimal(12, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  invoiceUrl   String?             @db.Text
  items        PurchaseOrderItem[]
  branchId     String?             @db.VarChar(36)
  branch       Branch?             @relation(fields: [branchId], references: [id])

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.VarChar(36)
  purchaseOrderId String        @db.VarChar(36)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String        @db.VarChar(36)
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  orderedQty      Decimal       @db.Decimal(12, 3)
  receivedQty     Decimal       @default(0.000) @db.Decimal(12, 3)
  unitPrice       Decimal       @db.Decimal(10, 2)
}

model Order {
  id          String      @id @default(uuid()) @db.VarChar(36)
  tenantId    String      @db.VarChar(36)
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  branchId    String      @db.VarChar(36)
  branch      Branch      @relation(fields: [branchId], references: [id])
  orderNumber String      @db.VarChar(100)
  type        OrderType   @default(ONLINE)
  status      OrderStatus @default(PENDING)
  tableId     String?     @db.VarChar(36)
  table       Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerId  String?     @db.VarChar(36)
  customer    User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  subtotal    Decimal     @db.Decimal(10, 2)
  tax         Decimal     @default(0.00) @db.Decimal(10, 2)
  discount    Decimal     @default(0.00) @db.Decimal(10, 2)
  totalAmount Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([branchId, status])
}

model OrderItem {
  id         String              @id @default(uuid()) @db.VarChar(36)
  orderId    String              @db.VarChar(36)
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String              @db.VarChar(36)
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  quantity   Int                 @default(1)
  unitPrice  Decimal             @db.Decimal(10, 2)
  modifiers  OrderItemModifier[]
}

model OrderItemModifier {
  id          String       @id @default(uuid()) @db.VarChar(36)
  orderItemId String       @db.VarChar(36)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String       @db.VarChar(36)
  modifier    MenuModifier @relation(fields: [modifierId], references: [id])
  unitPrice   Decimal      @db.Decimal(10, 2)
}

model StockMovement {
  id           String       @id @default(uuid()) @db.VarChar(36)
  tenantId     String       @db.VarChar(36)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  branchId     String       @db.VarChar(36)
  branch       Branch       @relation(fields: [branchId], references: [id])
  ingredientId String       @db.VarChar(36)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])
  quantity     Decimal      @db.Decimal(12, 3)
  type         MovementType
  reason       String?      @db.VarChar(255)
  createdAt    DateTime     @default(now())
  createdById  String?      @db.VarChar(36)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([ingredientId, createdAt])
}

model WasteLog {
  id           String     @id @default(uuid()) @db.VarChar(36)
  tenantId     String     @db.VarChar(36)
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  branchId     String     @db.VarChar(36)
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId String     @db.VarChar(36)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(12, 3)
  cost         Decimal    @db.Decimal(10, 2)
  reason       String     @db.VarChar(255)
  employeeId   String     @db.VarChar(36)
  employee     User       @relation(fields: [employeeId], references: [id])
  createdAt    DateTime   @default(now())

  @@index([branchId, createdAt])
}

model StaffAttendance {
  id       String    @id @default(uuid()) @db.VarChar(36)
  tenantId String    @db.VarChar(36)
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  userId   String    @db.VarChar(36)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn  DateTime  @default(now())
  clockOut DateTime?

  @@index([userId, clockIn])
}

model Notification {
  id        String           @id @default(uuid()) @db.VarChar(36)
  tenantId  String           @db.VarChar(36)
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  userId    String           @db.VarChar(36)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String           @db.VarChar(150)
  message   String           @db.Text
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenantId    String   @db.VarChar(36)
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?  @db.VarChar(36)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   @db.VarChar(255)
  details     String?  @db.Text
  ipAddress   String?  @db.VarChar(45)
  createdAt   DateTime @default(now())

  @@index([tenantId, action, createdAt])
}

model SavedReport {
  id          String     @id @default(uuid()) @db.VarChar(36)
  tenantId    String     @db.VarChar(36)
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  branchId    String?    @db.VarChar(36)
  branch      Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String     @db.VarChar(150)
  type        ReportType
  payload     Json
  createdAt   DateTime   @default(now())
  createdById String?    @db.VarChar(36)
  createdBy   User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model CustomerProfile {
  id              String    @id @default(uuid()) @db.VarChar(36)
  userId          String    @unique @db.VarChar(36)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsBalance   Int       @default(0)
  membershipTier  String    @default("SILVER") @db.VarChar(50) // SILVER, GOLD, PLATINUM
  walletBalance   Decimal   @default(0.00) @db.Decimal(10, 2)
  birthday        DateTime?
  favoriteFood    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model GiftCard {
  id         String    @id @default(uuid()) @db.VarChar(36)
  tenantId   String    @db.VarChar(36)
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  code       String    @unique @db.VarChar(50)
  balance    Decimal   @db.Decimal(10, 2)
  expiryDate DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model Coupon {
  id             String    @id @default(uuid()) @db.VarChar(36)
  tenantId       String    @db.VarChar(36)
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  code           String    @unique @db.VarChar(50)
  discountType   String    @default("PERCENTAGE") @db.VarChar(20) // PERCENTAGE, FIXED
  value          Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal   @default(0.00) @db.Decimal(10, 2)
  expiryDate     DateTime?
  isActive       Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model Reservation {
  id              String            @id @default(uuid()) @db.VarChar(36)
  tenantId        String            @db.VarChar(36)
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  customerName    String            @db.VarChar(150)
  customerEmail   String            @db.VarChar(150)
  customerPhone   String            @db.VarChar(50)
  partySize       Int               @default(2)
  reservationTime DateTime
  status          ReservationStatus @default(PENDING)
  tableId         String?           @db.VarChar(36)
  table           Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
}

model WaitingList {
  id            String            @id @default(uuid()) @db.VarChar(36)
  tenantId      String            @db.VarChar(36)
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  customerName  String            @db.VarChar(150)
  customerPhone String            @db.VarChar(50)
  partySize     Int               @default(2)
  status        String            @default("WAITING") @db.VarChar(30) // WAITING, SEATED, CANCELLED
  createdAt     DateTime          @default(now())
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model EventBooking {
  id              String    @id @default(uuid()) @db.VarChar(36)
  tenantId        String    @db.VarChar(36)
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  branchId        String    @db.VarChar(36)
  branch          Branch    @relation(fields: [branchId], references: [id])
  title           String    @db.VarChar(150)
  customerName    String    @db.VarChar(150)
  customerPhone   String    @db.VarChar(50)
  guestCount      Int       @default(10)
  eventDate       DateTime
  cateringDetails String?   @db.Text
  totalCost       Decimal   @default(0.00) @db.Decimal(10, 2)
  status          String    @default("PENDING") @db.VarChar(30) // PENDING, CONFIRMED, COMPLETED, CANCELLED
  createdAt       DateTime  @default(now())
}

model NutritionInfo {
  id          String   @id @default(uuid()) @db.VarChar(36)
  menuItemId  String   @unique @db.VarChar(36)
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  calories    Int      @default(0)
  allergens   String?  @db.Text // Comma-separated list (e.g. Gluten, Nuts)
  protein     Decimal  @default(0.0) @db.Decimal(6, 2)
  carbs       Decimal  @default(0.0) @db.Decimal(6, 2)
  fat         Decimal  @default(0.0) @db.Decimal(6, 2)
}

model ProductionBatch {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenantId    String   @db.VarChar(36)
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String   @db.VarChar(36) // Central Kitchen Branch
  branch      Branch   @relation(fields: [branchId], references: [id])
  recipeId    String   @db.VarChar(36) // maps to recipe identifier or text
  name        String   @db.VarChar(150)
  batchQty    Decimal  @db.Decimal(10, 2)
  status      String   @default("PENDING") @db.VarChar(30) // PENDING, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())
}

// --- Platform / Ops enums ---

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeliveryJobStatus {
  ASSIGNED
  EN_ROUTE
  DELIVERED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  COMPLETED
  REJECTED
}

enum ApprovalType {
  PO
  EXPENSE
  WASTE
  INVENTORY
  TRANSFER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IntegrationChannel {
  EMAIL
  SMS
  WHATSAPP
  PAYMENT
}

// --- Platform / SaaS models ---

model SubscriptionPlan {
  id           String           @id @default(uuid()) @db.VarChar(36)
  name         String           @db.VarChar(150)
  tier         SubscriptionTier
  priceMonthly Decimal          @db.Decimal(12, 2)
  maxBranches  Int
  maxEmployees Int
  features     Json?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
}

model Invoice {
  id          String    @id @default(uuid()) @db.VarChar(36)
  tenantId    String    @db.VarChar(36)
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("USD") @db.VarChar(10)
  status      String    @db.VarChar(50)
  dueDate     DateTime?
  paidAt      DateTime?
  description String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([tenantId, status])
}

model PlanFeatureFlag {
  id        String           @id @default(uuid()) @db.VarChar(36)
  planTier  SubscriptionTier
  featureKey String          @db.VarChar(100)
  enabled   Boolean          @default(true)

  @@unique([planTier, featureKey])
}

model SupportTicket {
  id             String       @id @default(uuid()) @db.VarChar(36)
  tenantId       String?      @db.VarChar(36)
  tenant         Tenant?      @relation(fields: [tenantId], references: [id])
  subject        String       @db.VarChar(255)
  description    String       @db.Text
  status         TicketStatus @default(OPEN)
  priority       String       @default("MEDIUM") @db.VarChar(30)
  requesterEmail String       @db.VarChar(150)
  assigneeName   String?      @db.VarChar(150)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, createdAt])
}

model PlatformIntegration {
  id        String             @id @default(uuid()) @db.VarChar(36)
  name      String             @db.VarChar(150)
  channel   IntegrationChannel
  config    Json?
  isActive  Boolean            @default(true)
  updatedAt DateTime           @updatedAt
}

model ApiKeyRecord {
  id         String    @id @default(uuid()) @db.VarChar(36)
  name       String    @db.VarChar(150)
  keyPrefix  String    @db.VarChar(20)
  keyHash    String    @db.VarChar(255)
  tenantId   String?   @db.VarChar(36)
  createdBy  String?   @db.VarChar(36)
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyPrefix])
}

model GlobalTaxSetting {
  id        String  @id @default(uuid()) @db.VarChar(36)
  country   String  @db.VarChar(100)
  taxName   String  @db.VarChar(100)
  rate      Decimal @db.Decimal(8, 4)
  isDefault Boolean @default(false)
}

model BackupPolicy {
  id            String    @id @default(uuid()) @db.VarChar(36)
  name          String    @db.VarChar(150)
  frequency     String    @db.VarChar(50)
  retentionDays Int
  isActive      Boolean   @default(true)
  lastRunAt     DateTime?
}

model SystemAnnouncement {
  id        String    @id @default(uuid()) @db.VarChar(36)
  title     String    @db.VarChar(255)
  body      String    @db.Text
  audience  String    @default("ALL") @db.VarChar(50)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

/// Singleton-style platform branding for the admin panel (Super Admin System Settings).
model PlatformBranding {
  id        String   @id @default(uuid()) @db.VarChar(36)
  appName   String   @default("Restaurant Ops") @db.VarChar(100)
  logo      String?  @db.Text
  favicon   String?  @db.Text
  updatedAt DateTime @updatedAt
}

// --- Tenant ops modules ---

model Expense {
  id           String        @id @default(uuid()) @db.VarChar(36)
  tenantId     String        @db.VarChar(36)
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  branchId     String?       @db.VarChar(36)
  amount       Decimal       @db.Decimal(12, 2)
  category     String        @db.VarChar(100)
  description  String        @db.Text
  status       ExpenseStatus @default(PENDING)
  createdById  String        @db.VarChar(36)
  approvedById String?       @db.VarChar(36)
  createdAt    DateTime      @default(now())

  @@index([tenantId, status, createdAt])
}

model StaffSchedule {
  id        String   @id @default(uuid()) @db.VarChar(36)
  tenantId  String   @db.VarChar(36)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  branchId  String   @db.VarChar(36)
  userId    String   @db.VarChar(36)
  shiftDate DateTime
  startTime String   @db.VarChar(10)
  endTime   String   @db.VarChar(10)
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([tenantId, branchId, shiftDate])
}

model LeaveRequest {
  id        String      @id @default(uuid()) @db.VarChar(36)
  tenantId  String      @db.VarChar(36)
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  userId    String      @db.VarChar(36)
  startDate DateTime
  endDate   DateTime
  leaveType String      @db.VarChar(50)
  status    LeaveStatus @default(PENDING)
  reason    String?     @db.Text
  createdAt DateTime    @default(now())

  @@index([tenantId, userId, status])
}

model DeliveryJob {
  id           String            @id @default(uuid()) @db.VarChar(36)
  tenantId     String            @db.VarChar(36)
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  orderId      String?           @db.VarChar(36)
  branchId     String?           @db.VarChar(36)
  assigneeId   String?           @db.VarChar(36)
  status       DeliveryJobStatus @default(ASSIGNED)
  address      String            @db.Text
  proofUrl     String?           @db.Text
  codAmount    Decimal?          @db.Decimal(12, 2)
  customerName String?           @db.VarChar(150)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([tenantId, status, createdAt])
}

model MarketingCampaign {
  id          String         @id @default(uuid()) @db.VarChar(36)
  tenantId    String         @db.VarChar(36)
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  name        String         @db.VarChar(150)
  channel     String         @db.VarChar(50)
  status      CampaignStatus @default(DRAFT)
  audience    String?        @db.VarChar(255)
  content     String         @db.Text
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([tenantId, status])
}

model StockTransferRequest {
  id            String         @id @default(uuid()) @db.VarChar(36)
  tenantId      String         @db.VarChar(36)
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  fromBranchId  String         @db.VarChar(36)
  toBranchId    String         @db.VarChar(36)
  ingredientId  String         @db.VarChar(36)
  quantity      Decimal        @db.Decimal(12, 3)
  status        TransferStatus @default(REQUESTED)
  requestedById String         @db.VarChar(36)
  approvedById  String?        @db.VarChar(36)
  createdAt     DateTime       @default(now())

  @@index([tenantId, status, createdAt])
}

model ApprovalRequest {
  id            String         @id @default(uuid()) @db.VarChar(36)
  tenantId      String         @db.VarChar(36)
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  type          ApprovalType
  refId         String         @db.VarChar(36)
  title         String         @db.VarChar(255)
  status        ApprovalStatus @default(PENDING)
  requestedById String         @db.VarChar(36)
  decidedById   String?        @db.VarChar(36)
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())

  @@index([tenantId, status, type])
}
