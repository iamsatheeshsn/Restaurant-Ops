DATABASE_URL="mysql://root@127.0.0.1:3306/restaurant_ops"
PORT=5000
JWT_SECRET="change-me-access-secret"
REFRESH_SECRET="change-me-refresh-secret"
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
# Required for public storefront routes when the client omits X-Tenant-ID (single-tenant/demo).
# Omit in multi-tenant production so every public request must send X-Tenant-ID.
DEFAULT_TENANT_ID=""
